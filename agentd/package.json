{
  "name": "@neuroengine/agentd",
  "version": "0.1.0",
  "description": "NeuroEngine Agent Daemon — local stateless daemon for the operational agent",
  "type": "module",
  "main": "dist/boot.js",
  "bin": {
    "agent": "./bin/agent.js"
  },
  "scripts": {
